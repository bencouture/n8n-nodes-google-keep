{
  "name": "n8n-nodes-google-keep",
  "version": "0.1.1",
  "description": "n8n community node for the Google Keep API",
  "keywords": [
    "n8n-community-node-package",
    "google-keep",
    "n8n"
  ],
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/bencouture/n8n-nodes-google-keep",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bencouture/n8n-nodes-google-keep.git"
  },
  "author": {
    "name": "Ben Couture"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "test": "jest",
    "lint": "eslint nodes credentials --ext .ts"
  },
