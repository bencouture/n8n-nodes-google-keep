{
  "name": "n8n-nodes-google-keep",
  "version": "0.1.3",
  "description": "n8n community node for the Google Keep API",
  "keywords": [
    "n8n-community-node-package",
    "google-keep",
    "n8n"
  ],
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/bencouture/n8n-nodes-google-keep",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bencouture/n8n-nodes-google-keep.git"
  },
  "author": {
    "name": "Ben Couture",
    "email": "bencouture@protonmail.com"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "n8n-node build",
    "test": "jest",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/GoogleKeepServiceAccountApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GoogleKeep/GoogleKeep.node.js"
    ]
  },
  "dependencies": {
    "google-auth-library": "^9.15.0"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.38.8",
    "@types/jest": "^29.5.14",
    "eslint": "9.32.0",
    "jest": "^29.7.0",
    "n8n-workflow": "1.70.0",
    "nock": "^13.5.6",
    "ts-jest": "^29.2.5",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "isolated-vm": "5.0.4"
  }
}
